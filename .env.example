
# =====================
# DATABASE CONFIGURATION
# =====================
DATABASE_URL=sqlite:///./data/yogavibe.db
# For production with PostgreSQL:
# DATABASE_URL=postgresql://username:password@postgres:5432/yogavibe

# =====================
# CORS CONFIGURATION
# =====================
CORS_ORIGINS=http://localhost:3000,http://localhost:80,http://localhost

# =====================
# MINIO / S3 STORAGE
# =====================
FILE_STORAGE_PROVIDER=s3
# Internal service URL (used by backend to access MinIO)
S3_ENDPOINT_URL=http://minio:9000
# Public URL (used by frontend/clients to access files)
S3_PUBLIC_ENDPOINT_URL=http://localhost:9000
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
# AWS_ACCESS_KEY_ID=minioadmin
# AWS_SECRET_ACCESS_KEY=minioadmin

# =====================
# BACKEND API CONFIGURATION
# =====================
DEBUG=false
API_TITLE=YogaVibe API
API_VERSION=1.0.0

# =====================
# SECURITY
# =====================
# JWT secret key - set your own value before deploy
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change-me-before-deploy

# Bootstrap admin setup - DISABLED BY DEFAULT
ENABLE_BOOTSTRAP_ADMIN=false
# BOOTSTRAP_ADMIN_TOKEN=setup-token

# =====================
# SMTP / EMAIL (Optional)
# =====================
# SMTP_SERVER=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# SMTP_FROM_EMAIL=noreply@yogavibe.app

# =====================
# FRONTEND CONFIGURATION
# =====================
REACT_APP_API_URL=http://localhost/api
REACT_APP_ENV=production

# =====================
# LOGGING
# =====================
LOG_LEVEL=WARNING
# LOG_FILE=./logs/yogavibe.log

# =====================
# STORAGE CONFIGURATION
# =====================
STORAGE_PUBLIC_BASE_URL=http://localhost:8000
MAX_UPLOAD_SIZE_MB=50
ALLOWED_FILE_EXTENSIONS=pdf,doc,docx,jpg,jpeg,png,gif,txt,zip

# =====================
# OPTIONAL SERVICES
# =====================
# WEATHER_API_KEY=your-weather-api-key
# REDIS_URL=redis://redis:6379/0
