{
  "name": "yogavibe-app",
  "version": "1.0.0",
  "description": "Платформа для поиска менторов по йоге - соединяем искателей с опытными наставниками",
  "author": "YogaVibe Team",
  "license": "MIT",
  "keywords": [
    "yoga",
    "mentor",
    "wellness",
    "react",
    "spa"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/yogavibe-app.git"
  },
  "homepage": "https://yogavibe.example.com",
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "test:ci": "react-scripts test --watchAll=false --coverage",
    "test:unit": "react-scripts test --watchAll=false --testPathPattern=\\.unit\\.test\\.",
    "test:integration": "react-scripts test --watchAll=false --testPathPattern=\\.integration\\.test\\.",
    "test:e2e": "react-scripts test --watchAll=false --testPathPattern=\\.e2e\\.test\\. --passWithNoTests",
    "eject": "react-scripts eject",
    "lint": "eslint src --ext .js,.jsx",
    "format": "prettier --write \"src/**/*.{js,jsx,css,json}\"",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d build"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^7.9.5",
    "react-toastify": "^11.0.5"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.3.5",
    "@types/react": "^18.2.61",
    "@types/react-dom": "^18.2.19",
    "eslint": "^8.57.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^4.6.2",
    "gh-pages": "^6.3.0",
    "prettier": "^3.7.4",
    "react-scripts": "5.0.1",
    "typescript": "^4.9.5"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  },
  "private": true,
  "jest": {
    "moduleNameMapper": {
      "^react-router-dom$": "<rootDir>/src/test/reactRouterDomMock.tsx"
    },
    "coverageThreshold": {
      "global": {
        "statements": 15,
        "branches": 10,
        "functions": 10,
        "lines": 15
      }
    }
  }
}
